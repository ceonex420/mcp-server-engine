# ============================================================================
# Odiseo MCP Server - Environment Configuration
# ============================================================================
# Copy this file to .env and configure for your environment:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED]
# Optional variables show their default values
#
# Documentation: See config/settings.py for detailed field descriptions
# ============================================================================


# ============================================================================
# 1. DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection settings. Requires extensions: pgvector, pg_trgm, unaccent
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example: postgresql://mcp_user:secure_pass@localhost:5432/mcpdb
# ============================================================================

# [REQUIRED] PostgreSQL connection URL
DATABASE_URL=postgresql://mcp_user:your_secure_password_here@localhost:5432/mcpdb

# Database schema for all tables (default: test)
# Use different schemas for dev/staging/prod environments
SCHEMA_NAME=test


# ============================================================================
# 2. AI/EMBEDDINGS CONFIGURATION (Google Gemini)
# ============================================================================
# Google AI API settings for semantic search embeddings
# Get your API key: https://aistudio.google.com/apikey
# ============================================================================

# [REQUIRED] Google API key for Gemini AI embeddings
GOOGLE_API_KEY=your_google_api_key_here

# Embedding model name (default: gemini-embedding-001)
# Available: gemini-embedding-001 (supports up to 3072 dimensions)
EMBEDDING_MODEL=gemini-embedding-001

# Vector dimension for embeddings (default: 1536)
# Range: 256-3072. Higher = more accuracy, more memory/slower
# NOTE: Must match database column type: vector(EMBEDDING_DIMENSION)
EMBEDDING_DIMENSION=1536

# Batch size for embedding operations (default: 8)
BATCH_SIZE=8


# ============================================================================
# 3. SERVER CONFIGURATION
# ============================================================================
# MCP server runtime settings
# ============================================================================

# HTTP port for MCP server (default: 8009)
# Range: 1024-65535
MCP_PORT=8009

# Enable debug mode (default: false)
# WARNING: Set to false in production for security
DEBUG_MODE=false

# Maximum concurrent requests per worker (default: 50)
# Range: 1-500. Adjust based on server resources
MAX_CONCURRENT_REQUESTS=50


# ============================================================================
# 4. LOGGING CONFIGURATION
# ============================================================================
# Structured logging with automatic file rotation
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
# Use WARNING or ERROR in production to reduce noise
LOG_LEVEL=INFO

# Log files directory, relative to mcp_server/ (default: logs)
LOG_DIR=logs

# Maximum log file size in MB before rotation (default: 10)
LOG_MAX_SIZE_MB=10

# Number of backup log files to keep (default: 5)
LOG_BACKUP_COUNT=5


# ============================================================================
# 5. EMAIL SERVICE INTEGRATION
# ============================================================================
# HTTP client settings for external email microservice
# Pattern: Fire-and-forget with circuit breaker for fault tolerance
# ============================================================================

# Enable email service integration (default: true)
EMAIL_SERVICE_ENABLED=true

# Email microservice base URL (default: http://localhost:8001)
EMAIL_SERVICE_BASE_URL=http://localhost:8001

# API key for email service authentication (default: empty = no auth)
EMAIL_SERVICE_API_KEY=

# --- HTTP Client Settings ---

# Request timeout in seconds (default: 5.0, max: 30)
EMAIL_SERVICE_TIMEOUT_SECONDS=5.0

# Maximum retry attempts for transient failures (default: 2, max: 5)
EMAIL_SERVICE_MAX_RETRIES=2

# Initial delay between retries in seconds (default: 0.5)
# Uses exponential backoff: delay * 2^attempt
EMAIL_SERVICE_RETRY_DELAY_SECONDS=0.5

# --- Circuit Breaker Settings ---

# Failures before circuit opens (default: 5)
EMAIL_SERVICE_CIRCUIT_BREAKER_THRESHOLD=5

# Seconds before circuit allows retry (default: 60)
EMAIL_SERVICE_CIRCUIT_BREAKER_TIMEOUT_SECONDS=60


# ============================================================================
# 6. GOOGLE CALENDAR CONFIGURATION
# ============================================================================
# Optional integration for booking/appointment sync with Google Calendar
# Requires: Google Cloud service account with Calendar API enabled
# ============================================================================

# Enable Google Calendar integration (default: false)
GOOGLE_CALENDAR_ENABLED=false

# Path to service account JSON credentials (default: credentials/service-account.json)
# Relative paths resolved from project root
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials/service-account.json

# Calendar ID for bookings (default: primary)
# Use 'primary' for default calendar or specific calendar ID
GOOGLE_CALENDAR_ID=primary

# Timezone for events in IANA format (default: America/Costa_Rica)
# Examples: America/New_York, Europe/London, Asia/Tokyo
GOOGLE_CALENDAR_TIMEZONE=America/Costa_Rica


# ============================================================================
# 7. BOOKING CONFIGURATION
# ============================================================================
# Appointment scheduling settings
# ============================================================================

# Default appointment duration in minutes (default: 60, max: 480)
BOOKING_DEFAULT_DURATION_MINUTES=60

# Time slot interval for availability checks in minutes (default: 30)
# Must be <= BOOKING_DEFAULT_DURATION_MINUTES
BOOKING_SLOT_INTERVAL_MINUTES=30

# Maximum days in advance for booking (default: 30)
BOOKING_ADVANCE_BOOKING_DAYS=30

# Minimum advance time required for booking in minutes (default: 60)
# Prevents last-minute bookings
BOOKING_MIN_ADVANCE_MINUTES=60

# Maximum appointments allowed per day (default: 10)
BOOKING_MAX_DAILY_APPOINTMENTS=10


# ============================================================================
# 8. BOOKING INPUT PARSER (Advanced)
# ============================================================================
# Confidence thresholds for natural language booking input parsing
# Values: 0.0-1.0 (higher = stricter matching)
# ============================================================================

# Confidence threshold for reschedule/cancel classification (default: 0.75)
BOOKING_CHOICE_CONFIDENCE_THRESHOLD=0.75

# Confidence for partial word matches (default: 0.95)
BOOKING_PARTIAL_MATCH_CONFIDENCE=0.95

# Minimum string length for substring matching (default: 3)
BOOKING_MIN_KEYWORD_LENGTH=3

# SequenceMatcher threshold for fuzzy matching (default: 0.75)
BOOKING_FUZZY_MATCH_THRESHOLD=0.75

# Confidence for yes/no confirmation parsing (default: 0.75)
BOOKING_CONFIRMATION_THRESHOLD=0.75

# Threshold below which to ask for clarification (default: 0.6)
BOOKING_CLARIFICATION_THRESHOLD=0.6

# Email notification priority: 1=lowest, 10=highest (default: 5)
BOOKING_EMAIL_QUEUE_PRIORITY=5


# ============================================================================
# 9. PGVECTOR CONFIGURATION
# ============================================================================
# PostgreSQL pgvector extension tuning for vector similarity search
# ============================================================================

# Number of IVF lists for vector index (default: 100)
# Higher = faster search but more memory usage
# Recommendation: sqrt(total_rows) for optimal performance
PGVECTOR_IVF_LISTS=100


# ============================================================================
# 10. OTP (ONE-TIME PASSWORD) CONFIGURATION
# ============================================================================
# Secure OTP generation and verification for email verification flows.
# Uses cryptographically secure random generation (Python secrets module).
#
# Security: OTP codes are hashed (SHA-256) before storage, never plaintext.
# ============================================================================

# Enable OTP generation and verification tools (default: true)
OTP_ENABLED=true

# OTP code length: 4-8 digits (default: 6)
# Longer codes = more secure but harder to enter
OTP_CODE_LENGTH=6

# OTP validity period in minutes (default: 10)
# Range: 1-60 minutes. Shorter = more secure
OTP_EXPIRY_MINUTES=10

# Maximum verification attempts before OTP is invalidated (default: 3)
# Prevents brute-force attacks. Range: 1-10
OTP_MAX_ATTEMPTS=3

# Cooldown period between OTP requests for same email (default: 60 seconds)
# Prevents spam/abuse. Range: 30-300 seconds
OTP_COOLDOWN_SECONDS=60

# Hash algorithm for storing OTP codes (default: sha256)
# Options: sha256, sha384, sha512
# NOTE: Never stores raw OTP codes - always hashed
OTP_HASH_ALGORITHM=sha256

# Default purpose for OTP verification (default: email_verification)
# Used when purpose is not explicitly specified
OTP_PURPOSE_VERIFICATION=email_verification
