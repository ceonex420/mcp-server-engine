# =============================================================================
# Production Environment Variables - Odiseo MCP Server
# =============================================================================
# This file documents all environment variables for Cloud Run deployment.
# DO NOT commit secrets to this file - use Secret Manager instead.
#
# Usage:
#   - Copy to .env for local testing
#   - Use as reference for Cloud Run --set-env-vars
#   - Secrets are injected via --set-secrets flag
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_NAME=Odiseo MCP Server
APP_VERSION=1.5.0
ENVIRONMENT=production
DEBUG_MODE=false

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Cloud Run injects PORT automatically (usually 8080)
HOST=0.0.0.0
PORT=8080
MCP_PORT=8080

# -----------------------------------------------------------------------------
# Google Cloud Configuration
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=gen-lang-client-0329024102
GCP_LOCATION=us-central1

# Service account credentials are handled by Cloud Run Workload Identity
# Use Application Default Credentials in Cloud Run
USE_ADC=true

# -----------------------------------------------------------------------------
# Database Configuration (Secret Manager)
# -----------------------------------------------------------------------------
# DATABASE_URL is injected via Secret Manager: database-url:latest
# Format: postgresql://user:password@host:port/database
SCHEMA_NAME=test

# -----------------------------------------------------------------------------
# AI/Embeddings Configuration
# -----------------------------------------------------------------------------
# GOOGLE_API_KEY is injected via Secret Manager
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=1536
BATCH_SIZE=8

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
# Note: In Cloud Run, logs go to stdout/stderr and are captured by Cloud Logging
# File logging is disabled in production (LOG_DIR not set)

# -----------------------------------------------------------------------------
# Concurrency Configuration
# -----------------------------------------------------------------------------
MAX_CONCURRENT_REQUESTS=50

# -----------------------------------------------------------------------------
# Email Service Configuration
# -----------------------------------------------------------------------------
EMAIL_SERVICE_ENABLED=true
EMAIL_SERVICE_BASE_URL=https://email-service-69054835734.us-central1.run.app
EMAIL_SERVICE_TIMEOUT_SECONDS=5.0
EMAIL_SERVICE_MAX_RETRIES=2
EMAIL_SERVICE_CIRCUIT_BREAKER_THRESHOLD=5
EMAIL_SERVICE_CIRCUIT_BREAKER_TIMEOUT_SECONDS=60

# -----------------------------------------------------------------------------
# Google Calendar Configuration
# -----------------------------------------------------------------------------
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_TIMEZONE=America/Costa_Rica

# -----------------------------------------------------------------------------
# Booking Configuration
# -----------------------------------------------------------------------------
BOOKING_DEFAULT_DURATION_MINUTES=60
BOOKING_SLOT_INTERVAL_MINUTES=30
BOOKING_ADVANCE_BOOKING_DAYS=30
BOOKING_MIN_ADVANCE_MINUTES=60
BOOKING_MAX_DAILY_APPOINTMENTS=10

# -----------------------------------------------------------------------------
# OTP Configuration
# -----------------------------------------------------------------------------
OTP_ENABLED=true
OTP_CODE_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_COOLDOWN_SECONDS=60
OTP_HASH_ALGORITHM=sha256

# -----------------------------------------------------------------------------
# pgvector Configuration
# -----------------------------------------------------------------------------
PGVECTOR_IVF_LISTS=100

# =============================================================================
# SECRETS (Stored in Secret Manager)
# =============================================================================
# Only DATABASE_URL is stored in Secret Manager:
#
# --set-secrets=DATABASE_URL=database-url:latest
#
# GOOGLE_API_KEY is NOT needed in production:
# - Cloud Run uses Application Default Credentials (USE_ADC=true)
# - Service account has roles/aiplatform.user for Gemini embeddings
#
# For local development, set GOOGLE_API_KEY in .env file
# =============================================================================
